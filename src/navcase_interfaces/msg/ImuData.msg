#   加速度计
float32 accel_x              # X轴加速度 (m/s²)
float32 accel_y              # Y轴加速度 (m/s²)
float32 accel_z              # Z轴加速度 (m/s²)
#   陀螺仪
float32 gyro_x               # X轴角速度 (rad/s)
float32 gyro_y               # Y轴角速度 (rad/s)
float32 gyro_z               # Z轴角速度 (rad/s)
#   磁力计
float32 mag_x                # X轴磁场强度 (uT)
float32 mag_y                # Y轴磁场强度 (uT)
float32 mag_z                # Z轴磁场强度 (uT)
#   姿态角
float32 roll                 # 横滚角 (度)
float32 pitch                # 俯仰角 (度)
float32 yaw                  # 偏航角 (度)
#   置信度
float32 orientation_confidence     #   姿态置信度 (0-1)
