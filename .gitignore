# ROS2 工作空间默认生成的目录
build/
install/
log/

# CMake / C++ 编译生成文件
CMakeLists.txt.user
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Testing/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
CMakeUserPresets.json

# C++ 编译中间文件和目标文件
*.o
*.obj
*.a
*.so
*.dylib
*.out
*.elf

# Python 缓存文件 (ROS2项目中可能包含部分Python脚本或启动文件)
__pycache__/
*.py[cod]
*$py.class
*.so

# 操作系统自动生成的文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / 编辑器相关
.vscode/
.idea/
cmake-build-*/
*.swp
*.swo
*~
